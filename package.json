{
  "name": "fphoto",
  "version": "1.0.0",
  "type": "module",
  "description": "Windows desktop app for filtering and copying photo files by image code.",
  "author": "Tung",
  "license": "UNLICENSED",
  "homepage": "https://github.com/tung78952/FPhoto",
  "repository": {
    "type": "git",
    "url": "https://github.com/tung78952/FPhoto.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "generate:icon": "powershell -ExecutionPolicy Bypass -File scripts/generate-icon.ps1",
    "verify:search": "tsx scripts/verify-search-parser.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/be-vietnam-pro": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@tesseract.js-data/eng": "^1.0.0",
    "electron-updater": "^6.6.2",
    "exifr": "^7.1.3",
    "exiftool-vendored": "^35.21.0",
    "node-windows-ocr": "^1.1.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.22",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.3.5"
  },
  "build": {
    "appId": "com.fphoto.app",
    "productName": "FPhoto",
    "copyright": "Copyright © 2026 Tung",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "afterPack": "scripts/patch-windows-icon.cjs",
    "asarUnpack": [
      "node_modules/node-windows-ocr/bin/**/*",
      "node_modules/tesseract.js/src/worker-script/**/*"
    ],
    "files": [
      "out/**/*",
      "node_modules/node-windows-ocr/**/*",
      "node_modules/tesseract.js/**/*",
      "node_modules/tesseract.js-core/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/@tesseract.js-data/eng/4.0.0_best_int",
        "to": "ocr/tessdata",
        "filter": [
          "eng.traineddata.gz"
        ]
      },
      {
        "from": "node_modules/tesseract.js-core",
        "to": "ocr/tesseract-core",
        "filter": [
          "*.js",
          "*.wasm"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "executableName": "FPhoto",
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "FPhoto",
      "uninstallDisplayName": "FPhoto"
    }
  }
}
